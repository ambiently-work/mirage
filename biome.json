{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"files": {
		"includes": ["**", "!**/node_modules", "!**/dist", "!**/tsconfig.tsbuildinfo"]
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "warn"
			},
			"suspicious": {
				"noTemplateCurlyInString": "off",
				"noExplicitAny": "warn",
				"noThenProperty": "warn",
				"noAssignInExpressions": "warn"
			},
			"correctness": {
				"noUnusedFunctionParameters": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	}
}
