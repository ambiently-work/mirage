{
	"name": "@ambiently-work/vfs",
	"version": "0.0.1",
	"description": "Mirage — a pluggable in-process virtual filesystem. Pure-JS, browser and server, with snapshot/restore, layered overlays, and disk/repo loaders.",
	"license": "MIT",
	"author": "ambiently",
	"homepage": "https://github.com/ambiently-work/mirage",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ambiently-work/mirage.git"
	},
	"bugs": "https://github.com/ambiently-work/mirage/issues",
	"keywords": [
		"virtual-filesystem",
		"vfs",
		"in-memory",
		"filesystem",
		"sandbox",
		"agent",
		"snapshot",
		"overlay",
		"browser"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./disk": "./src/disk.ts",
		"./git": "./src/git.ts"
	},
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"default": "./dist/index.js"
			},
			"./disk": {
				"types": "./dist/disk.d.ts",
				"import": "./dist/disk.js",
				"default": "./dist/disk.js"
			},
			"./git": {
				"types": "./dist/git.d.ts",
				"import": "./dist/git.js",
				"default": "./dist/git.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b --force",
		"test": "bun test",
		"check": "biome check .",
		"format": "biome format --write .",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"@types/bun": "^1.3.0",
		"typescript": "^5.9.2"
	}
}
