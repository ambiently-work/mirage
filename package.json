{
	"name": "@ambiently-work/mirage",
	"version": "0.1.0",
	"description": "Mirage — a pluggable in-process virtual filesystem. Pure-JS, browser and server, with snapshot/restore, layered overlays, and disk/repo loaders.",
	"license": "MIT",
	"author": "ambiently",
	"homepage": "https://github.com/ambiently-work/mirage",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ambiently-work/mirage.git"
	},
	"bugs": "https://github.com/ambiently-work/mirage/issues",
	"keywords": [
		"mirage",
		"virtual-filesystem",
		"in-memory",
		"filesystem",
		"sandbox",
		"agent",
		"snapshot",
		"overlay",
		"browser"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./disk": "./src/disk.ts",
		"./git": "./src/git/index.ts",
		"./git-cli": "./src/git-cli.ts",
		"./hooks": "./src/adapters/hooked.ts"
	},
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"default": "./dist/index.js"
			},
			"./disk": {
				"types": "./dist/disk.d.ts",
				"import": "./dist/disk.js",
				"default": "./dist/disk.js"
			},
			"./git": {
				"types": "./dist/git/index.d.ts",
				"import": "./dist/git/index.js",
				"default": "./dist/git/index.js"
			},
			"./git-cli": {
				"types": "./dist/git-cli.d.ts",
				"import": "./dist/git-cli.js",
				"default": "./dist/git-cli.js"
			},
			"./hooks": {
				"types": "./dist/adapters/hooked.d.ts",
				"import": "./dist/adapters/hooked.js",
				"default": "./dist/adapters/hooked.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b --force",
		"test": "bun test",
		"check": "biome check .",
		"format": "biome format --write .",
		"knip": "knip",
		"audit": "bun audit --prod",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"prepare": "lefthook install || true",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/bun": "1.3.13",
		"knip": "^6.11.0",
		"lefthook": "^2.1.6",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"isomorphic-git": "^1.37.6",
		"wasm-git": "^0.0.14"
	}
}
